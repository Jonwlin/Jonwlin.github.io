{
  "name": "brain-dump",
  "version": "1.0.0",
  "private": true,
  "description": "Brain Dump — searchable collection of guides, reviews, and project write-ups",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "deploy": "next build && rm -rf ../brain-dump && cp -r out ../brain-dump && touch ../brain-dump/.nojekyll && echo 'Exported to ../brain-dump'",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
